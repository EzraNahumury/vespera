# Copy values into GitHub Secrets / Variables or a local .env file.
# Local usage example:
#   cd frontend
#   $env:PRIVATE_KEY="0x..."
#   $env:DRY_RUN="1"
#   npm run tx:vespera

# Required for live writes. In GitHub, store this as secret VESPERA_TX_PRIVATE_KEY.
PRIVATE_KEY=0x...

# Optional. Defaults to Celo Forno.
RPC_URL=https://forno.celo.org

# Defaults are the current Celo mainnet deployment from vespera-sc/deployments.
AGENT_REGISTRY_ADDRESS=0x67aF4795C9C76677F252d1b60DA7b240DB3A7A10
GROUP_REGISTRY_ADDRESS=0x493613949d63b63b02A58Ee899e9c6cd647Ae86b
TREASURY_ADDRESS=0x4D84DD953FCdecfD54eA50e4ce6Ea809D9f9DAbd
VOTING_ENGINE_ADDRESS=0xCa8C94Fb21C5d6b8f786e6d549dAb2a8Fe2f07f6

# Common controls.
ACTION=auto
DRY_RUN=1
GROUP_ADDRESS=
REQUEST_ID=
MAX_GROUPS=10

# Auto mode controls.
# AUTO_DEPOSIT is off by default because Arisan deposits are real contributions.
AUTO_DEPOSIT=0
AUTO_INIT_VOTE=1
AUTO_CAST_VOTE=1
AUTO_FINALIZE=1

# Voting controls.
CONFIDENCE_BPS=8500
VOTE_SUPPORT=1

# configure-agent action.
AGENT_ADDRESS=
POLICY_URI=ipfs://vespera-policy-balanced-v1

# request-withdrawal action.
WITHDRAW_AMOUNT=
WITHDRAW_AMOUNT_WEI=
REASON_URI=ipfs://vespera-automation-request
