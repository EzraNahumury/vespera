# Copy to .env and fill in. Never commit the real .env.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
# Optional: off-chain Requester Agent signer granted AGENT_ROLE (default: deployer)
AGENT_ADDRESS=
# Optional: credits minted per 1 CELO deposited (default 1000, Voxel-style)
CREDIT_PER_CELO=1000
# Optional: native CELO (wei) to seed as withdrawal liquidity headroom (default 0)
LIQUIDITY_CELO=
